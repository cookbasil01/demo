---
import { siteInfo } from '../data/site';
---

<section class="location-contact" id="contacto">
  <div class="container container-split">
    
    <div class="contact-info">
      <span class="section-subtitle">Visítanos o Pide a Domicilio</span>
      <h2 class="section-title">Encuéntranos Aquí</h2>
      
      <div class="info-list">
        <!-- Address -->
        <div class="info-item">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <div>
            <h3>Nuestra Ubicación</h3>
            <p>{siteInfo.location.address}</p>
          </div>
        </div>
        
        <!-- Schedule -->
        <div class="info-item">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <div>
            <h3>Horario de Atención</h3>
            <p>{siteInfo.schedule}</p>
          </div>
        </div>
        
        <!-- WhatsApp -->
        <div class="info-item">
          <div class="info-icon text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <div>
            <h3>Teléfono / WhatsApp</h3>
            <p>{siteInfo.contact.phone}</p>
          </div>
        </div>
      </div>
      
      <div class="action-buttons">
        <a href={siteInfo.contact.whatsappLink} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          Hacer un Pedido
        </a>
        <a href={siteInfo.location.mapUrl} class="btn btn-outline" target="_blank" rel="noopener noreferrer">
          Cómo Llegar
        </a>
      </div>
    </div>
    
    <div class="map-container">
      <div class="map-placeholder">
        <!-- You can embed a real Google Map iframe here -->
        <img src="/images/map-placeholder.jpg" alt="Mapa de ubicación en Medellín" />
        <div class="map-overlay">
          <div class="map-pin">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="var(--color-primary)" stroke="var(--color-bg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <p>Belén, Medellín</p>
        </div>
      </div>
    </div>
    
  </div>
</section>

<style>
  .location-contact {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-bg);
  }
  
  .container-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  
  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }
  
  .info-icon {
    background-color: var(--color-surface-light);
    color: var(--color-primary);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .info-item h3 {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
    color: var(--color-text);
  }
  
  .info-item p {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.5;
  }
  
  .action-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .map-container {
    height: 100%;
    min-height: 450px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    box-shadow: var(--shadow-md);
  }
  
  .map-placeholder {
    width: 100%;
    height: 100%;
    position: relative;
    background-color: #222;
  }
  
  .map-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .map-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(13,13,13,0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }
  
  .map-placeholder:hover .map-overlay {
    background-color: rgba(13,13,13,0.2);
  }
  
  .map-pin {
    animation: bounce 2s infinite;
  }
  
  .map-overlay p {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    text-shadow: 0 2px 4px rgba(0,0,0,0.8);
    margin-top: 0.5rem;
  }
  
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
    40% {transform: translateY(-20px);}
    60% {transform: translateY(-10px);}
  }
  
  @media (max-width: 992px) {
    .container-split {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .map-container {
      min-height: 350px;
    }
  }
</style>
