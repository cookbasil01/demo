---
import { siteInfo } from '../data/site';
---

<section class="trust-features">
  <div class="container">
    <div class="features-grid">
      <!-- Rating -->
      <div class="feature-card highlight">
        <div class="icon-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
        </div>
        <div class="feature-content">
          <h3>Top Rating 4.6</h3>
          <p>Más de 500 reseñas confirman nuestro sabor brutal.</p>
        </div>
      </div>
      
      <!-- Ubicación -->
      <div class="feature-card">
        <div class="icon-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        </div>
        <div class="feature-content">
          <h3>Ubicación Ideal</h3>
          <p>Encuéntranos en Belén, el corazón gastronómico.</p>
        </div>
      </div>
      
      <!-- Horario -->
      <div class="feature-card">
        <div class="icon-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        </div>
        <div class="feature-content">
          <h3>Abiertos a Diario</h3>
          <p>{siteInfo.schedule}</p>
        </div>
      </div>
      
      <!-- Servicio -->
      <div class="feature-card">
        <div class="icon-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </div>
        <div class="feature-content">
          <h3>Múltiples Opciones</h3>
          <p>Domicilio rápido, retiro y consumo en el lugar.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-features {
    padding: var(--spacing-md) 0;
    margin-top: -4rem; /* Overlap hero a bit */
    position: relative;
    z-index: 10;
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  
  .feature-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(255,255,255,0.05);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  
  .feature-card:hover {
    transform: translateY(-5px);
    border-color: rgba(242, 169, 0, 0.3);
  }
  
  .feature-card.highlight {
    background: linear-gradient(145deg, var(--color-surface-light), var(--color-surface));
    border-color: var(--color-primary);
  }
  
  .feature-card.highlight .icon-wrap {
    color: var(--color-primary);
    background-color: rgba(242, 169, 0, 0.1);
  }
  
  .icon-wrap {
    color: var(--color-text);
    background-color: var(--color-surface-light);
    padding: 1rem;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .feature-content h3 {
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }
  
  .feature-content p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  
  @media (max-width: 768px) {
    .trust-features {
      margin-top: 0;
      padding: var(--spacing-lg) 0 var(--spacing-md);
    }
  }
</style>
