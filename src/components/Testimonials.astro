---
import { testimonials } from '../data/site';
---

<section class="testimonials">
  <div class="container">
    <div class="section-header text-center">
      <span class="section-subtitle">Prueba Social</span>
      <h2 class="section-title">Lo Que Dicen Los Clientes</h2>
    </div>
    
    <div class="testimonials-grid">
      {testimonials.map(t => (
        <div class="testimonial-card">
          <div class="quote-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="var(--color-primary)" opacity="0.2"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          <div class="stars">
            {Array.from({length: t.rating}).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            ))}
          </div>
          <p class="testimonial-text">"{t.text}"</p>
          <div class="testimonial-author">
            <div class="author-avatar">{t.name.charAt(0)}</div>
            <div class="author-info">
              <h4 class="author-name">{t.name}</h4>
              <span class="author-role">{t.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="testimonials-footer text-center">
      <p>Nuestra calificación global es <strong class="text-primary">4.6/5</strong> en Google y Rappi.</p>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-surface);
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  
  .section-header {
    margin-bottom: var(--spacing-lg);
  }
  
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }
  
  .testimonial-card {
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    position: relative;
    border: 1px solid rgba(255,255,255,0.03);
    box-shadow: var(--shadow-sm);
  }
  
  .quote-icon {
    position: absolute;
    top: 2rem;
    right: 2rem;
  }
  
  .stars {
    display: flex;
    gap: 0.2rem;
    margin-bottom: 1.5rem;
  }
  
  .testimonial-text {
    font-size: 1.1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 2rem;
    font-style: italic;
  }
  
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 1.5rem;
  }
  
  .author-avatar {
    width: 45px;
    height: 45px;
    background-color: var(--color-surface-light);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
  }
  
  .author-name {
    font-size: 1.1rem;
    margin-bottom: 0.2rem;
  }
  
  .author-role {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  
  .testimonials-footer {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }
</style>
